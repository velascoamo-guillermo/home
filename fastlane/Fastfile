default_platform :ios

platform :ios do

  desc "Run all unit tests"
  lane :test do
    xcconfig_content = <<~XCCONFIG
      SUPABASE_URL = #{ENV.fetch("SUPABASE_URL")}
      SUPABASE_ANON_KEY = #{ENV.fetch("SUPABASE_ANON_KEY")}
    XCCONFIG
    File.write("../Config.xcconfig", xcconfig_content)

    run_tests(
      project: ENV["PROJECT"],
      scheme: ENV["SCHEME"],
      destination: ENV["DESTINATION"],
      clean: true,
      code_coverage: true,
      output_directory: "fastlane/test_output",
      output_types: "junit"
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci

    xcconfig_content = <<~XCCONFIG
      SUPABASE_URL = #{ENV.fetch("SUPABASE_URL")}
      SUPABASE_ANON_KEY = #{ENV.fetch("SUPABASE_ANON_KEY")}
    XCCONFIG
    File.write("../Config.xcconfig", xcconfig_content)

    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT"),
      is_key_content_base64: true
    )

    sync_code_signing(
      type: "appstore",
      readonly: true
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: ENV["PROJECT"],
      targets: ["Home"],
      team_id: "523MDDHYGD",
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore com.guillermovelasco.home"
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: ENV["PROJECT"],
      targets: ["HomeWidget"],
      team_id: "523MDDHYGD",
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore com.guillermovelasco.home.HomeWidget"
    )

    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M")
    )

    build_app(
      project: ENV["PROJECT"],
      scheme: ENV["SCHEME"],
      export_method: "app-store",
      output_directory: "fastlane/build_output",
      output_name: "Home.ipa",
      export_options: {
        provisioningProfiles: {
          "com.guillermovelasco.home" => "match AppStore com.guillermovelasco.home",
          "com.guillermovelasco.home.HomeWidget" => "match AppStore com.guillermovelasco.home.HomeWidget"
        }
      }
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end

end
